# Git / VCS
.git
.gitignore

# Python
**/__pycache__
**/*.py[cod]
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.venv
**/venv
*.egg-info

# Secrets (do not bake into image)
.env
.env.*
!.env.example

# Frontend — install and local build artifacts (image builds from source)
frontend/node_modules
frontend/dist

# OS / editor
**/.DS_Store
Thumbs.db

# Jupyter (not needed at runtime)
**/.ipynb_checkpoints
.ipynb_checkpoints
**/*.ipynb
