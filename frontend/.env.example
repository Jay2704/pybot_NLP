# --- Bundled into the client (VITE_*) ---

# Optional: absolute API origin without trailing slash. Use when the UI and API are on
# different hosts. Leave unset for same-origin deployments (Hugging Face Docker Space,
# or local Docker / single-container setups).
#
# VITE_API_URL=https://your-api.example.com

# --- Dev server only (read by Vite, not embedded in the app) ---

# Where `npm run dev` proxies API traffic. Default below if unset.
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
